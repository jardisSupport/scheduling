{
    "name": "jardissupport/scheduling",
    "description": "Cron expression parsing and task scheduling with fluent API and timezone support",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2"
    },
    "autoload": {
        "psr-4": {
            "JardisSupport\\Scheduling\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisSupport\\Scheduling\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisSupport/scheduling",
    "support": {
        "issues": "https://github.com/jardisSupport/scheduling/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "scheduling",
        "cron",
        "task",
        "timer",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
